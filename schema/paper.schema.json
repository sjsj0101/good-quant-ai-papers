{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sjsj0101/good-quant-ai-papers/blob/main/schema/paper.schema.json",
  "title": "Quantitative AI paper record",
  "description": "Metadata contract for one record in data/papers.yaml.",
  "$defs": {
    "http_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^(?!.*\\s)(?!.*%(?![0-9A-Fa-f]{2}))[Hh][Tt][Tt][Pp][Ss]?://(?:[^/?#@\\s]+(?::[^/?#@\\s]*)?@)?(?:\\[[0-9A-Fa-f:.]+\\]|[^/?#:@\\s]+)(?::0*(?:[0-9]{1,4}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:[/?#][^\\s]*)?$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "authors",
    "venue",
    "year",
    "track",
    "presentation",
    "official_url",
    "paper_url",
    "topics",
    "summary",
    "why_it_matters",
    "status",
    "verified_on"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+){2,}(?![\\s\\S])"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "venue": {
      "enum": [
        "ICML",
        "NeurIPS",
        "ICLR",
        "KDD",
        "AAAI",
        "IJCAI",
        "WWW",
        "WSDM",
        "SIGIR",
        "AISTATS",
        "ACM ICAIF"
      ]
    },
    "year": {
      "type": "integer"
    },
    "track": {
      "enum": ["main", "workshop", "position", "affinity"]
    },
    "presentation": {
      "enum": ["oral", "spotlight", "poster", "not-specified"]
    },
    "official_url": {
      "$ref": "#/$defs/http_url"
    },
    "paper_url": {
      "$ref": "#/$defs/http_url"
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "asset-allocation",
          "portfolio-optimization",
          "alpha-modeling",
          "financial-forecasting",
          "factor-investing",
          "risk-management",
          "market-regimes",
          "market-microstructure",
          "execution",
          "derivatives",
          "market-simulation",
          "synthetic-data",
          "alternative-data",
          "financial-agents",
          "evaluation"
        ]
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "status": {
      "enum": ["accepted", "published"]
    },
    "verified_on": {
      "type": "string",
      "format": "date"
    },
    "arxiv_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "openreview_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "doi": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "code_url": {
      "$ref": "#/$defs/http_url"
    },
    "project_url": {
      "$ref": "#/$defs/http_url"
    },
    "asset_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "equities",
          "fixed-income",
          "derivatives",
          "FX",
          "commodities",
          "crypto",
          "multi-asset"
        ]
      }
    },
    "data_frequency": {
      "enum": [
        "tick",
        "intraday",
        "daily",
        "weekly",
        "monthly",
        "mixed",
        "not-applicable"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "methods": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  }
}
